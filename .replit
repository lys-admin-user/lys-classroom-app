modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["unzip", "poppler_utils"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000






[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "start"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "audit"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "audit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/audit-deps.mjs"

[workflows.workflow.metadata]
isValidation = true

[agent]
integrations = ["javascript_mem_db:1.0.0", "javascript_openai:1.0.0", "javascript_replit_auth:2.0.0", "hubspot:1.0.0", "stripe:1.0.0", "javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
RESEND_FROM_EMAIL = "Laddering Your Success <no-reply@lyslessonplanning.com>"
BOOTSTRAP_ADMIN_EMAIL = "bayo@maskil.dev"
