# ─────────────────────────────────────────────────────────────────────────
# LYS Educational Platform — environment variables
#
# Copy to `.env` for local dev (or set these in your host's dashboard, e.g.
# Replit Secrets or Render Environment). Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────
# Postgres connection string (Neon/RDS/Render Postgres/etc).
DATABASE_URL=postgres://user:password@host:5432/dbname

# Signs the express-session cookie. Use a long random string.
SESSION_SECRET=replace-with-a-long-random-string

# AES-256-GCM key for field-level encryption (student notes, MFA secrets).
# Must be stable — rotating it makes existing encrypted data unreadable.
APP_ENCRYPTION_KEY=replace-with-a-32-byte-random-key

# Set to "production" on the live deployment. Drives secure cookies, CSP,
# indexability, and disables all dev-only auth bypasses. Leave unset in dev.
NODE_ENV=development

# Public, externally-reachable base URL of this app (no trailing slash).
# Used to build Stripe webhook URLs, email links, and embed/canonical URLs.
# On Render, RENDER_EXTERNAL_URL is provided automatically and used as a
# fallback, but setting PUBLIC_BASE_URL explicitly is recommended.
PUBLIC_BASE_URL=https://your-app.onrender.com

# ── Authentication (Clerk) ────────────────────────────────────────────────
# From the Clerk dashboard → API Keys. The publishable key is safe for the
# browser; the secret key is server-only. VITE_CLERK_PUBLISHABLE_KEY must equal
# CLERK_PUBLISHABLE_KEY (Vite only exposes VITE_-prefixed vars to the client).
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ── Payments (Stripe) ─────────────────────────────────────────────────────
# Standard Stripe API keys (dashboard → Developers → API keys).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret (dashboard → Developers → Webhooks → your endpoint).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── AI (OpenAI) ───────────────────────────────────────────────────────────
# Standard OpenAI key. (On Replit, the managed integration provisions
# AI_INTEGRATIONS_OPENAI_API_KEY and bootstrap-env.ts bridges it to this.)
OPENAI_API_KEY=sk-xxx
# Optional: override the OpenAI base URL (e.g. a proxy).
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Email (optional — pick one provider) ──────────────────────────────────
# Used for MFA email codes, digests, and notifications. If none are set, email
# is logged instead of sent (login MFA falls back gracefully).
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=LYS <you@example.com>
# Before verifying a domain in Resend, use their shared test sender (delivers
# only to your own Resend account email): RESEND_FROM_EMAIL=LYS <onboarding@resend.dev>
# SENDGRID_API_KEY=SG.xxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=you@example.com
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── HubSpot (optional) ────────────────────────────────────────────────────
# NOTE: HubSpot currently still uses the Replit connector proxy and is OUT OF
# SCOPE for the Render migration. If you rely on HubSpot off-Replit, migrate it
# to a standard private-app access token separately.
# HUBSPOT_ACCESS_TOKEN=pat-xxx
